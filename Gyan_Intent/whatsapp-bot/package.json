{
  "name": "gyan-whatsapp-bot",
  "version": "1.0.0",
  "description": "WhatsApp Web.js bot for Gyan_Intent EdTech platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --run",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=tests/unit --run",
    "test:property": "jest --testPathPattern=tests/property --run",
    "test:integration": "jest --testPathPattern=tests/integration --run",
    "test:coverage": "jest --coverage --run",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "whatsapp",
    "bot",
    "edtech",
    "education"
  ],
  "author": "Gyan_Intent",
  "license": "MIT",
  "dependencies": {
    "whatsapp-web.js": "^1.23.0",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.12",
    "express": "^4.18.2",
    "winston": "^3.11.0",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
